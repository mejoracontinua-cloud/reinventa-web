{
  "rewrites": [
    { "source": "/taller-imagen-personal", "destination": "/taller-imagen-personal.html" },
    { "source": "/reservar", "destination": "/api/reservar" },
    { "source": "/aviso-de-privacidad", "destination": "/aviso-de-privacidad.html" },
    { "source": "/reservar.html", "destination": "/reservar.html" },
    { "source": "/api/fase", "destination": "/api/fase" },
    { "source": "/entrada", "destination": "/entrada.html" },
    { "source": "/api/entrada", "destination": "/api/entrada" },
    { "source": "/hub", "destination": "/hub.html" },
    { "source": "/api/hub", "destination": "/api/hub" },
    { "source": "/api/encuesta", "destination": "/api/encuesta" },
    { "source": "/api/encuesta-previa", "destination": "/api/encuesta-previa" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/api/admin", "destination": "/api/admin" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
